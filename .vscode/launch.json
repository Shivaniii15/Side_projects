{
  "version": "0.2.0",
  "configurations": [
    {
        "name": "Attach to Chrome",
        "port": 9222,
        "request": "attach",
        "type": "chrome",
        "webRoot": "${workspaceFolder}"
    },
    {
        "name": "Launch Chrome",
        "request": "launch",
        "type": "chrome",
        "url": "http://localhost:8080",
        "webRoot": "${workspaceFolder}"
    },
    {
        "name": "Run Streamlit Dashboard",
        "type": "python",
        "request": "launch",
        "module": "streamlit",
        "args": ["run", "${workspaceFolder}/dashboard.py"],
        "console": "integratedTerminal",
        "cwd": "${workspaceFolder}",
        "justMyCode": true
    }
  ]
}
